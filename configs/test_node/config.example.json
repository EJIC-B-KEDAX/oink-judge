{
    "my_id": "my_id",
    "ports": {
        "database": 5432,
        "content_service": 9102,
        "dispatcher": 9101
    },
    "hosts": {
        "content_service": "127.0.0.1",
        "dispatcher": "127.0.0.1"
    },
    "database": {
        "host": "127.0.0.1",
        "port": 5432,
        "username": "my_username",
        "dbname": "my_dbname"
    },
    "directories": {
        "submissions": "submissions",
        "submissions_zip": "submissions/.zips",
        "problems": "problems",
        "problems_zip": "problems/.zips",
        "scripts": "scripts",
        "certs": "certs",
        "plugins": "plugins/test_node"
    },
    "sessions": {
        "dispatcher": "SSLSessionClient(Authorizing({\"auth_token_path\": \"my_auth_token_path, in credentials\", \"inner_type\": \"Pinging(InvokerProtocol)\"}))",
        "content_service": "SSLSessionClient(Authorizing({\"auth_token_path\": \"my_auth_token_path, in credentials\", \"inner_type\": \"Pinging(ContentClientProtocol)\"}))"
    },
    "start_messages": {
        "content_service": "{\"connection_type\": \"content_storage\"}",
        "dispatcher": "{\"connection_type\": \"test_node\"}"
    },
    "timings": {
        "ping_interval": 5,
        "pong_timeout": 3,
        "full_rescan_interval": 3600
    },
    "testing": {
        "meta_file": "logs/meta.txt",
        "checker_err_file": "logs/checker_err.txt",
        "checker_out_file": "logs/checker_out.txt"
    },
    "logger": {
        "log_levels": {
            "default": 1
        }
    }
}