{
    "my_port": 9101,
    "connection_handler_type": "SimpleConnectionHandler",
    "ports": {
        "database": 5432,
        "content_service": 9102
    },
    "hosts": {
        "content_service": "127.0.0.1"
    },
    "database": {
        "host": "127.0.0.1",
        "port": 5432,
        "username": "my_username",
        "dbname": "my_dbname"
    },
    "directories": {
        "submissions": "submissions",
        "submissions_zip": "submissions/.zips",
        "problems": "problems",
        "problems_zip": "problems/.zips",
        "scripts": "scripts",
        "certs": "certs",
        "plugins": "plugins/dispatcher"
    },
    "sessions": {
        "FastAPI": "SSLSessionServer(AuthRequired({\"auth_token_path\": \"my_auth_token_path, in credentials\", \"inner_type\": \"Ponging(ProtocolWithFastAPI)\"}))",
        "content_service": "SSLSessionClient(Authorizing({\"auth_token_path\": \"my_auth_token_path, in credentials\", \"inner_type\": \"Pinging(ContentClientProtocol)\"}))",
        "test_node": "SSLSessionServer(AuthRequired({\"auth_token_path\": \"my_auth_token_path, in credentials\", \"inner_type\": \"Ponging(ProtocolWithInvoker)\"}))"
    },
    "start_messages": {
        "content_service": "{\"connection_type\": \"content_storage\"}"
    },
    "timings": {
        "ping_interval": 5,
        "pong_timeout": 3,
        "full_rescan_interval": 3600
    },
    "logger": {
        "log_levels": {
            "default": 1
        }
    }
}