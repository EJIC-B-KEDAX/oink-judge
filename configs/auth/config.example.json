{
    "my_port": 9001,
    "connection_handler_type": "SimpleConnectionHandler",
    "ports": {
        "database": 5432
    },
    "database": {
        "host": "127.0.0.1",
        "port": 5432,
        "username": "my_username",
        "dbname": "my_dbname"
    },
    "sessions": {
        "FastAPI": "SSLSessionServer(AuthRequired({\"auth_token_path\": \"my_auth_token_path, in credentials\", \"inner_type\": \"Ponging(ProtocolWithFastAPI)\"}))"
    },
    "directories": {
        "certs": "certs",
        "plugins": "plugins/auth_service"
    },
    "timings": {
        "valid_session_time": 3600,
        "ping_interval": 5,
        "pong_timeout": 3
    },
    "logger": {
        "log_levels": {
            "default": 1
        }
    }
}